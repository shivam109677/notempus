{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "stack:up",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "-f", "infra/docker-compose.yml", "up", "--build"],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "stack:down",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "-f", "infra/docker-compose.yml", "down", "--remove-orphans"],
      "problemMatcher": []
    },
    {
      "label": "workspace:typecheck",
      "type": "shell",
      "command": "${workspaceFolder}/.tools/node/bin/pnpm",
      "args": ["typecheck"],
      "options": {
        "env": {
          "PATH": "${workspaceFolder}/.tools/node/bin:${env:PATH}",
          "COREPACK_HOME": "${workspaceFolder}/.tools/corepack"
        }
      },
      "problemMatcher": ["$tsc"]
    }
  ]
}
