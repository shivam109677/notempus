# Core
NODE_ENV=development
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_SIGNALING_WS_URL=ws://localhost:4003/ws
NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.5:3000
SIGNALING_WS_URL=ws://localhost:4003/ws
APP_DOMAIN=chat.example.com
LETSENCRYPT_EMAIL=ops@chat.example.com

# Production overrides (set before `docker compose -f infra/docker-compose.prod.yml up`)
# NEXT_PUBLIC_GATEWAY_URL=https://chat.example.com
# NEXT_PUBLIC_SIGNALING_WS_URL=wss://chat.example.com/ws
# SIGNALING_WS_URL=wss://chat.example.com/ws

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=notempus
POSTGRES_PORT=5432
DATABASE_URL=postgresql://app:app@postgres:5432/notempus

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_ISSUER=notempus
JWT_AUDIENCE=notempus-users
JWT_SECRET=replace-with-strong-secret
ADMIN_PANEL_USER=owner
ADMIN_PANEL_PASSWORD=replace-with-owner-password

# API Gateway upstreams (host development defaults)
MATCHING_SERVICE_URL=http://localhost:4001
BILLING_SERVICE_URL=http://localhost:4002
PAYMENTS_SERVICE_URL=http://localhost:4004
VERIFICATION_SERVICE_URL=http://localhost:4005
MODERATION_SERVICE_URL=http://localhost:4006

# Billing
PAID_RATE_PER_MINUTE_PAISE=1000
PLATFORM_SHARE_BPS=3000
FEMALE_SHARE_BPS=5000
REWARD_SHARE_BPS=2000
BILLING_TICK_SECONDS=1
MIN_PAYOUT_PAISE=10000

# Payments
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# Verification
FACE_MATCH_THRESHOLD=0.75
LIVENESS_THRESHOLD=0.80

# Fraud telemetry worker
FRAUD_TELEMETRY_BATCH_SIZE=50
FRAUD_TELEMETRY_WORKER_INTERVAL_MS=1000

# WebRTC
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:coturn:3478
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword

# Production TURN examples
# STUN_URL=stun:turn.chat.example.com:3478
# TURN_URL=turns:turn.chat.example.com:5349?transport=tcp
